---
import { SITE } from "@/consts";
---

<section
  id="vision"
  class="relative w-full min-h-[100svh] flex flex-col justify-center py-32 px-8 md:px-12 lg:px-24 overflow-hidden"
>
  <!-- Background: dark with radial glow anchored to the graphic position -->
  <div class="absolute inset-0 z-0 bg-obsidian">
    <div
      class="absolute top-1/2 right-[5%] -translate-y-1/2 w-[500px] h-[500px] bg-[radial-gradient(ellipse_at_center,rgba(79,70,229,0.10)_0%,transparent_70%)]"
    >
    </div>
  </div>

  <!-- Hero Graphic: positioned absolutely, right-aligned, vertically centered (DESKTOP, lg+) -->
  <div
    class="hidden lg:block absolute right-12 xl:right-24 top-1/2 -translate-y-1/2 z-[1] w-[380px] xl:w-[440px]"
  >
    <img
      src="/assets/sm-upscaled.png"
      alt={`${SITE.name} app showing AI-generated tattoo stencil output`}
      width="440"
      height="440"
      class="w-full object-contain drop-shadow-[0_0_60px_rgba(79,70,229,0.15)]"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto">
    <div class="flex flex-col gap-8 max-w-2xl">
      <!--
        HALO ARTIFACT — mobile / tablet only (lg:hidden, so the desktop layout
        above stays pixel-identical). On phones the desktop graphic is hidden,
        which left the hero text-only with a dead upper region. This restores the
        signature skull→neural brand mark as the focal point AND the logo
        presence: it floats, centered, above the eyebrow on a slow-rotating
        indigo conic halo + radial glow. It reuses the desktop image src
        (browser-cached — no extra request) and the established .sa-ring halo
        idiom. Animations are CSS-only, fully visible at rest (no-JS safe), and
        neutralized under prefers-reduced-motion by the global media query.
        The glow bed is kept inside the viewport (inset-[-10%]) so nothing clips
        at the screen edge on a 320px phone.
      -->
      <div
        class="lg:hidden sm-hero-art relative mx-auto mb-2 grid place-items-center w-[min(76vw,300px)] aspect-square"
      >
        <!-- Radial indigo glow bed (contained — no horizontal clip at 320px) -->
        <div
          class="pointer-events-none absolute inset-[-10%] rounded-full bg-[radial-gradient(circle_at_center,rgba(79,70,229,0.24)_0%,rgba(79,70,229,0.07)_44%,transparent_70%)] blur-[2px]"
        >
        </div>
        <!-- Rotating conic halo (reuses the .sa-ring idiom), masked to a thin ring -->
        <div
          class="sm-hero-ring sa-ring pointer-events-none absolute inset-[5%] rounded-full opacity-60"
        >
        </div>
        <!-- Static fine inner ring for crisp containment -->
        <div
          class="pointer-events-none absolute inset-[5%] rounded-full border border-stencil/15"
        >
        </div>
        <!-- The artwork itself, levitating above the halo -->
        <img
          src="/assets/sm-upscaled.png"
          alt={`${SITE.name} — a tattoo reference transformed into a pure-line AI stencil`}
          width="440"
          height="440"
          class="sm-hero-float relative z-[1] w-[88%] object-contain drop-shadow-[0_0_50px_rgba(79,70,229,0.28)]"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>

      <div
        class="flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-neutral-400"
      >
        <span class="w-8 h-px bg-stencil"></span>
        <span>AI-Powered Tattoo Stencils</span>
      </div>
      <!--
        "TRANSLATE" is a single unbreakable 9-letter word; in Syne ExtraBold it
        measures ~9.84em wide, so any fixed size large enough for desktop
        overflows narrow phones and gets clipped by the section's overflow-hidden.
        Fluid clamp() sizes it to the viewport: it fills the column edge-to-edge
        on phones (intentional, never clipped) and caps at 6rem (= the old
        lg:text-8xl) on desktop. 7.8vw is the largest coefficient that still fits
        a 320px screen, empirically measured against the live font.
      -->
      <h1
        class="font-display font-extrabold text-[clamp(1.5rem,7.8vw,6rem)] leading-[0.9] tracking-tight uppercase text-paper"
      >
        Translate<br />
        <span class="text-neutral-500">Vision.</span>
      </h1>
      <p
        class="font-sans text-lg md:text-xl font-light text-neutral-300 leading-relaxed text-balance max-w-md"
      >
        The first AI architecture built for the demands of high-end tattoo
        craft. Uncompromising precision. Pure lines. Zero noise.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 mt-2">
        <a
          href="#download"
          class="px-7 py-4 bg-paper text-obsidian text-sm font-bold uppercase tracking-widest rounded-sm hover:-translate-y-0.5 hover:shadow-[0_16px_32px_-8px_rgba(250,250,250,0.2)] transition-all duration-300 text-center"
        >
          Get Started Free
        </a>
        <a
          href="#engine"
          class="px-7 py-4 border border-ash/60 text-paper text-sm font-bold uppercase tracking-widest rounded-sm hover:border-paper/60 transition-all duration-300 text-center flex items-center justify-center gap-2"
        >
          <i class="ph ph-play text-base" aria-hidden="true"></i>
          See How It Works
        </a>
      </div>
    </div>
  </div>
</section>
