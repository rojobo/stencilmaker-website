---
import { SITE } from "@/consts";
---

<header
  class="absolute top-0 left-0 w-full p-8 md:p-12 z-40 flex justify-between items-start pointer-events-none"
>
  <a href="/" class="flex items-center gap-3 pointer-events-auto" aria-label={`${SITE.name} home`}>
    <img
      src="/assets/hero-graphic-light.png"
      alt=""
      width="80"
      height="80"
      class="w-16 h-16 md:w-20 md:h-20 object-contain"
      loading="eager"
      decoding="async"
    />
    <span class="font-display font-bold text-2xl md:text-3xl tracking-tight">
      {SITE.name}<span class="text-stencil text-3xl md:text-4xl leading-none">.</span>
    </span>
  </a>
  <div class="pointer-events-auto hidden md:block">
    <span class="text-xs font-mono text-neutral-500 uppercase tracking-widest">
      v2.0 // Neural Engine architecture
    </span>
  </div>
</header>
