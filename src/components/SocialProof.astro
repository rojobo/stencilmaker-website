---
import Icon from "@/components/Icon.astro";
---

<section class="w-full py-32 bg-obsidian relative overflow-hidden">
  <div
    class="absolute top-1/2 -translate-y-1/2 left-0 w-[200%] flex whitespace-nowrap opacity-[0.03] pointer-events-none select-none z-0"
    aria-hidden="true"
  >
    <h2 class="font-display text-[15vw] font-bold animate-marquee">
      TRUSTED BY MASTERS — BUILT FOR THE CRAFT — TRUSTED BY MASTERS —
    </h2>
  </div>

  <div
    class="max-w-4xl mx-auto px-8 relative z-10 text-center flex flex-col items-center"
  >
    <Icon name="quotes" weight="fill" class="text-4xl text-ash mb-8" aria-hidden="true" />
    <figure>
      <blockquote
        class="font-display text-2xl md:text-4xl font-medium leading-normal mb-12"
      >
        "It eliminated an hour of iPad tracing per client. But more importantly,
        the stencil quality is fundamentally better than what a human hand can
        plot reliably at 3AM."
      </blockquote>

      <div class="w-px h-12 bg-ash mb-8 mx-auto"></div>

      <figcaption class="flex items-center gap-4 justify-center">
        <div class="w-12 h-12 rounded-full overflow-hidden bg-ink">
          <img
            src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=200&q=80"
            alt="Portrait of Elias Thorne, tattoo artist at Ghost Studio NYC"
            width="48"
            height="48"
            class="w-full h-full object-cover grayscale"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="text-left">
          <p class="font-bold text-paper uppercase tracking-wider text-sm">
            Elias Thorne
          </p>
          <p class="text-xs text-neutral-500 font-mono tracking-widest mt-1">
            GHOST STUDIO // NYC
          </p>
        </div>
      </figcaption>
    </figure>
  </div>
</section>
