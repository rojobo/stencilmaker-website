---
import { SITE, PRICING } from "@/consts";

/**
 * Structured data. Powers Google rich results AND Generative Engine
 * Optimization (GEO) — Perplexity, ChatGPT, Claude, Gemini, and Google AI
 * Overviews all consume Schema.org JSON-LD to ground answers about your
 * product. Keep this in sync with consts.ts and the visible page content.
 */

const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${SITE.url}#organization`,
  name: SITE.name,
  legalName: `${SITE.name} Inc.`,
  url: SITE.url,
  logo: {
    "@type": "ImageObject",
    url: new URL("/assets/sm-icon.png", SITE.url).toString(),
    width: 512,
    height: 512,
  },
  description: SITE.shortDescription,
  email: SITE.supportEmail,
  sameAs: [
    // TODO: add real social URLs once accounts are live
    "https://twitter.com/stencilmaker",
    "https://instagram.com/stencilmaker",
    "https://www.tiktok.com/@stencilmaker",
  ],
};

const website = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE.url}#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  inLanguage: SITE.locale.replace("_", "-"),
  publisher: { "@id": `${SITE.url}#organization` },
};

const softwareApp = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "@id": `${SITE.url}#app`,
  name: SITE.name,
  applicationCategory: "DesignApplication",
  applicationSubCategory: "Tattoo stencil generator",
  operatingSystem: "iOS, Android, Web",
  url: SITE.url,
  description: SITE.description,
  image: new URL("/assets/sm-upscaled.png", SITE.url).toString(),
  publisher: { "@id": `${SITE.url}#organization` },
  offers: [
    {
      "@type": "Offer",
      name: PRICING.free.name,
      price: String(PRICING.free.price),
      priceCurrency: PRICING.currency,
      category: "Free",
      availability: "https://schema.org/InStock",
    },
    {
      "@type": "Offer",
      name: `${PRICING.premium.name} (Monthly)`,
      price: String(PRICING.premium.monthly),
      priceCurrency: PRICING.currency,
      category: "Subscription",
      availability: "https://schema.org/InStock",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        price: String(PRICING.premium.monthly),
        priceCurrency: PRICING.currency,
        billingDuration: 1,
        unitCode: "MON",
      },
    },
    {
      "@type": "Offer",
      name: `${PRICING.premium.name} (Yearly)`,
      price: String(PRICING.premium.yearly),
      priceCurrency: PRICING.currency,
      category: "Subscription",
      availability: "https://schema.org/InStock",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        price: String(PRICING.premium.yearly),
        priceCurrency: PRICING.currency,
        billingDuration: 1,
        unitCode: "ANN",
      },
    },
    {
      "@type": "Offer",
      name: `${PRICING.credits.starter.name} credit pack`,
      price: String(PRICING.credits.starter.price),
      priceCurrency: PRICING.currency,
      category: "Credits",
      availability: "https://schema.org/InStock",
    },
    {
      "@type": "Offer",
      name: `${PRICING.credits.popular.name} credit pack`,
      price: String(PRICING.credits.popular.price),
      priceCurrency: PRICING.currency,
      category: "Credits",
      availability: "https://schema.org/InStock",
    },
    {
      "@type": "Offer",
      name: `${PRICING.credits.pro.name} credit pack`,
      price: String(PRICING.credits.pro.price),
      priceCurrency: PRICING.currency,
      category: "Credits",
      availability: "https://schema.org/InStock",
    },
  ],
  featureList: [
    "AI-powered tattoo stencil generation",
    "10 distinct style engines",
    "PNG, PDF, and SVG export",
    "Background removal",
    "Thermal printer support",
    "Cloud sync + offline mode",
  ],
};

const faq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is StencilMaker?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "StencilMaker is an AI-powered tool that turns any client reference photo into a clean, vector-grade tattoo stencil suitable for transfer paper. Professional tattoo artists use it to skip an hour of iPad tracing per session.",
      },
    },
    {
      "@type": "Question",
      name: "How does StencilMaker work?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Upload a reference image. StencilMaker's diffusion model isolates subject from background, strips lighting and noise artifacts, and outputs pure linework optimized for thermal transfer or hand tracing.",
      },
    },
    {
      "@type": "Question",
      name: "How much does StencilMaker cost?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `StencilMaker is free to start — 1 stencil per day, plus 10 free stencils to begin. Premium is $${PRICING.premium.monthly}/month or $${PRICING.premium.yearly}/year (save ${PRICING.premium.yearlySavingsPct}%, with a ${PRICING.premium.trialDays}-day free trial on the annual plan) and unlocks all style engines, PNG/PDF/SVG export, a cloud gallery, and up to 10 stencils per day (5/day on the monthly plan, 10/day on the annual plan). Prefer no subscription? Credit packs start at $${PRICING.credits.starter.price} for ${PRICING.credits.starter.credits} credits (about ${Math.floor(PRICING.credits.starter.credits / PRICING.creditsPerGeneration)} stencils) and never expire.`,
      },
    },
    {
      "@type": "Question",
      name: "What tattoo styles does StencilMaker support?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "StencilMaker ships with 10 style engines including Sacred Geometry, Japanese, Fine Line, Hyper-Realism, Traditional, Neo-Traditional, Blackwork, Dotwork, Linework, and Tribal.",
      },
    },
    {
      "@type": "Question",
      name: "Does StencilMaker support thermal printers?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. StencilMaker can send stencils directly to a Bluetooth or USB thermal printer without leaving the app.",
      },
    },
    {
      "@type": "Question",
      name: "Is StencilMaker available on iPhone, Android, and Web?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. StencilMaker runs natively on iOS and Android, plus a web app for desktop workflows. The same account syncs across all three.",
      },
    },
  ],
};
---

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(organization)}
/>
<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(website)}
/>
<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(softwareApp)}
/>
<script type="application/ld+json" is:inline set:html={JSON.stringify(faq)} />
